<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Big screen title in toolbars -->
    <style name="Text.ScreenTitle" parent="TextAppearance.Material3.HeadlineSmall">
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">-0.01</item>
    </style>

    <!-- Section header above groups of content -->
    <style name="Text.SectionHeader" parent="TextAppearance.Material3.TitleSmall">
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">?attr/colorOnSurface</item>
        <item name="android:letterSpacing">0.02</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:textSize">12sp</item>
    </style>

    <!-- Primary filled accent button -->
    <style name="Button.Accent" parent="Widget.Material3.Button">
        <item name="cornerRadius">14dp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="android:letterSpacing">0.01</item>
    </style>

    <style name="Button.AccentTonal" parent="Widget.Material3.Button.TonalButton">
        <item name="cornerRadius">14dp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="android:letterSpacing">0.01</item>
    </style>

</resources>
